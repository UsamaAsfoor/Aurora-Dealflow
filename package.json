{
  "name": "aurora-dealflow",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @aurora/db generate",
    "db:migrate": "pnpm --filter @aurora/db migrate",
    "db:seed": "pnpm --filter @aurora/db seed"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.8",
      "@types/react-dom": "19.1.6",
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  }
}
