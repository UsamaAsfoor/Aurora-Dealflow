# Database
DATABASE_URL=postgresql://aurora:aurora@localhost:5434/aurora_dealflow

# JWT Auth
JWT_SECRET=change-this-to-a-long-random-secret-at-least-32-characters

# API
PORT=4001
WEB_ORIGIN=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:4001

# Admin (comma-separated emails with access to /dashboard/admin)
ADMIN_EMAILS=you@yourcompany.com

# ATTOM Property Data
# Get a key at https://api.developer.attomdata.com (Account → Applications)
# Docs: https://api.developer.attomdata.com/docs
# Guides / Postman: https://api.developer.attomdata.com/docs/guides
ATTOM_API_KEY=your_attom_api_key
# Set to false to call live ATTOM (requires a real ATTOM_API_KEY)
ATTOM_USE_DEMO=true
# Local only: set true if ATTOM calls fail with SELF_SIGNED_CERT_IN_CHAIN
# ATTOM_TLS_INSECURE=true
# Optional override (default: https://api.gateway.attomdata.com/propertyapi/v1.0.0)
# ATTOM_BASE_URL=https://api.gateway.attomdata.com/propertyapi/v1.0.0

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_USE_DEMO=true

# Stripe (optional — demo billing works without keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio / Resend / Lob (optional — demo comms mode used when unset)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
RESEND_API_KEY=

# Mobile
EXPO_PUBLIC_API_URL=http://localhost:4001
